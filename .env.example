# -----------------------------------------------------------------------------
# Gemini Live tutor (browser connects to WS on same host as the API)
# -----------------------------------------------------------------------------

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE=Kore
GEMINI_TEMPERATURE=0.25

# -----------------------------------------------------------------------------
# Shared (subject inference via OpenAI optional paths, RAG/embeddings as used)
# -----------------------------------------------------------------------------

OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Ops
# -----------------------------------------------------------------------------

APP_ENV=development

# Listen port: use 8080 for local `uvicorn`. Docker image defaults to 80 (Azure ACA).
# For local Docker on 8080: set PORT=8080 in .env and run -p 8080:8080
PORT=8080


# Optional: Tesseract OCR language packs (default: eng)
# OCR_TESS_LANG=eng

# Optional: LibreOffice binary if not default (Linux Docker default shown)
# SOFFICE_PATH=/usr/bin/soffice
